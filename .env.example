# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=yggdrasil

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
API_KEY_HEADER=X-API-Key
API_KEYS=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Plugins (set to true to enable) ───────────────────────────────────────────
PLUGIN_DISCORD=false
PLUGIN_WEBSOCKET=false
PLUGIN_BIFORESTING_LINK=false

# ── Discord (required when PLUGIN_DISCORD=true) ──────────────────────────────
# DISCORD_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=
# DISCORD_SERVER_STATUS_CHANNEL_ID=             # staff: detailed crash/recovery/state messages
# DISCORD_SERVER_STATUS_PUBLIC_CHANNEL_ID=      # public: friendly started/stopped/crashed announcements
# DISCORD_SERVER_STATUS_WEBHOOK_USERNAME=Server Status   # identity for the public announcements
# DISCORD_SERVER_STATUS_WEBHOOK_AVATAR_URL=     # optional; falls back to the generic webhook/bot avatar
# DISCORD_DONATIONS_CHANNEL_ID=
# DISCORD_DONATIONS_LOG_CHANNEL_ID=
# DISCORD_SCREENSHOT_CHANNEL_ID=
# DISCORD_WEBHOOK_USERNAME=Yggdrasil
# DISCORD_WEBHOOK_AVATAR_URL=https://example.com/avatar.png

# ── Donations ─────────────────────────────────────────────────────────────────
# KOFI_VERIFICATION_TOKEN=
# PATREON_WEBHOOK_SECRET=

# ── Pterodactyl ───────────────────────────────────────────────────────────────
# PTERODACTYL_URL=https://panel.example.com
# PTERODACTYL_API_KEY=
# Pterodactyl server ID of the Bifrost/Velocity proxy — enables broadcasting
# PROXY_PTERODACTYL_SERVER_ID=

# ── Biforesting play-phase link (raw TCP from backend mods) ────────────────────
# Backends dial in directly and stream metrics/registry/quest/chunks. Required when
# PLUGIN_BIFORESTING_LINK=true: BIFORESTING_PSK (same PSK the mod was built with) OR a
# pre-derived BIFORESTING_AUTHKEY_HEX (64 hex chars). FIREWALL the link port to backend
# hosts only — it is plaintext TCP (HMAC = integrity/authenticity, not confidentiality).
# BIFORESTING_LINK_PORT=8765
# BIFORESTING_LINK_HOST=0.0.0.0
# BIFORESTING_PSK=
# BIFORESTING_AUTHKEY_HEX=

# ── Velocity Metrics ──────────────────────────────────────────────────────────
# VELOCITY_METRICS_URL=http://localhost:9100/metrics
