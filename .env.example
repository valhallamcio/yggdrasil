# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=yggdrasil

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
API_KEY_HEADER=X-API-Key
API_KEYS=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Plugins (set to true to enable) ───────────────────────────────────────────
PLUGIN_DISCORD=false
PLUGIN_WEBSOCKET=false

# ── Discord (required when PLUGIN_DISCORD=true) ──────────────────────────────
# DISCORD_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=
# DISCORD_SERVER_STATUS_CHANNEL_ID=
# DISCORD_DONATIONS_CHANNEL_ID=
# DISCORD_DONATIONS_LOG_CHANNEL_ID=
# DISCORD_SCREENSHOT_CHANNEL_ID=

# ── Donations ─────────────────────────────────────────────────────────────────
# KOFI_VERIFICATION_TOKEN=
# PATREON_WEBHOOK_SECRET=

# ── Pterodactyl ───────────────────────────────────────────────────────────────
# PTERODACTYL_URL=https://panel.example.com
# PTERODACTYL_API_KEY=

# ── Velocity Metrics ──────────────────────────────────────────────────────────
# VELOCITY_METRICS_URL=http://localhost:9100/metrics
